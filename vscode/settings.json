  "surround.custom": {
    "effect-error": {
      "description": "Effect.fail(...)",
      "label": "Effect.fail",
      "languageIds": ["typescript", "typescriptreact", "mdx"],
      "snippet": "return yield* Effect.fail($TM_SELECTED_TEXT)$0"
    },
    "effect-gen": {
      "description": "Effect.gen(function* () { ... })",
      "label": "Effect.gen",
      "languageIds": ["typescript", "typescriptreact", "mdx"],
      "snippet": "Effect.gen(function* () {\n  $TM_SELECTED_TEXT\n})$0"
    },
    "effect-trypromise": {
      "description": "Effect.tryPromise(...)",
      "label": "Effect.tryPromise",
      "languageIds": ["typescript", "typescriptreact", "mdx"],
      "snippet": "yield* Effect.tryPromise(async () => $TM_SELECTED_TEXT)$0"
    },
    "promise": {
      "description": "Promise<...>",
      "label": "Promise",
      "languageIds": ["typescript", "typescriptreact", "mdx"],
      "snippet": "Promise<$TM_SELECTED_TEXT>$0"
    },
    "readonly": {
      "description": "Readonly<...>",
      "label": "Readonly",
      "languageIds": ["typescript", "typescriptreact", "mdx"],
      "snippet": "Readonly<$TM_SELECTED_TEXT>$0"
    },
    "region": {
      "label": "Region",
      "languageIds": [
        "typescript",
        "typescriptreact",
        "mdx",
        "javascript",
        "javascriptreact"
      ],
      "snippet": "// =============================================================================\n// #region ${1:regionName}\n$TM_SELECTED_TEXT\n// #endregion ${1:regionName}"
    },
    "twJoin": {
      "description": "twJoin(...)",
      "label": "twJoin",
      "languageIds": ["typescript", "typescriptreact", "mdx"],
      "snippet": "{twJoin($TM_SELECTED_TEXT)}$0"
    }
  },
