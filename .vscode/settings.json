{
  "[css][graphql][html][javascript][javascriptreact][json][jsonc][markdown][mdx][scss][typescript][typescriptreact][yaml][toml]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[fish]": {
    "editor.formatOnSave": false
  },
  "editor.codeActionsOnSave": {
    "source.fixAll.biome": "explicit",
    "source.organizeImports": "never",
    "source.organizeImports.biome": "explicit"
  },
  "editor.formatOnSave": true,
  "editor.tabSize": 2,
  "files.associations": {
    "**/{bat,ripgrep}/config": "shellscript",
    "**/*.json": "jsonc",
    "**/git/*": "properties",
    "**/ignore": "ignore",
    "**/package.json": "json"
  },
  "files.eol": "\n",
  "files.insertFinalNewline": true,
  "json.schemas": [
    {
      "fileMatch": ["/_/vscode/settings.json"],
      "url": "vscode://schemas/settings/user"
    },
    {
      "fileMatch": ["/_/vscode/keybindings.json"],
      "url": "vscode://schemas/keybindings"
    },
    {
      "fileMatch": ["/_/vscode/mcp.json"],
      "url": "vscode://schemas/mcp"
    }
  ],
  "search.exclude": {
    "**/dist": true
  },
  "typescript.tsdk": "node_modules/typescript/lib"
}
