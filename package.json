{
  "name": "@ctison/root",
  "private": true,
  "type": "module",
  "workspaces": {
    "packages": [
      "pkgs/*",
      "pkgs/_/*"
    ],
    "catalogs": {
      "react": {
        "react": "19.2.5",
        "react-dom": "19.2.5"
      }
    }
  },
  "scripts": {
    "clean": "bun run -F './**' clean",
    "prepare": "husky",
    "pretest": "tsc",
    "test": "bun run -F './**' test",
    "update": "bun update -ri"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@types/bun": "1.3.12",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "cspell": "10.0.0",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "prettier": "3.8.3",
    "prettier-plugin-jsdoc": "1.8.0",
    "prettier-plugin-toml": "2.0.6",
    "sort-package-json": "3.6.1",
    "typescript": "6.0.3"
  },
  "packageManager": "bun@1.3.3"
}
