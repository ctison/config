{
  "name": "@ctison/root",
  "private": true,
  "type": "module",
  "workspaces": {
    "packages": [
      "pkgs/*",
      "pkgs/_/*"
    ]
  },
  "scripts": {
    "clean": "bun run -F './**' clean",
    "prepare": "husky",
    "pretest": "tsc",
    "test": "bun run -F './**' test",
    "update": "bun update -ri"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.5",
    "@types/bun": "1.3.2",
    "@types/node": "24.10.1",
    "cspell": "9.3.2",
    "husky": "9.1.7",
    "lint-staged": "16.2.6",
    "prettier": "3.6.2",
    "prettier-plugin-jsdoc": "1.5.0",
    "prettier-plugin-toml": "2.0.6",
    "sort-package-json": "3.4.0",
    "typescript": "5.9.3"
  },
  "packageManager": "bun@1.3.2"
}
