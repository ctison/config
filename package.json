{
  "name": "@ctison/config",
  "private": true,
  "type": "module",
  "scripts": {
    "format": "prettier -w .",
    "format:check": "prettier -c .",
    "image": "docker buildx bake --load",
    "prepare": "husky",
    "pretest": "tsc",
    "test": "bun test --pass-with-no-tests",
    "update": "bun update -ir"
  },
  "lint-staged": {
    "package.json": "sort-package-json",
    "*": "prettier -wu"
  },
  "prettier": {
    "jsxSingleQuote": true,
    "singleQuote": true
  },
  "devDependencies": {
    "@types/bun": "1.3.1",
    "husky": "9.1.7",
    "lint-staged": "16.2.6",
    "prettier": "3.6.2",
    "sort-package-json": "3.4.0",
    "typescript": "5.9.3"
  },
  "packageManager": "bun@1.3.1"
}
